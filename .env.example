# ──────────────────────────────────────────────
# BunnyCDN Storage
# ──────────────────────────────────────────────
BUNNY_STORAGE_ZONE=your-storage-zone
BUNNY_ACCESS_KEY=your-access-key
BUNNY_CDN_BASE_URL=https://your-zone.b-cdn.net

# ──────────────────────────────────────────────
# Proxy (optional)
# ──────────────────────────────────────────────
PROXY_URL=

# ──────────────────────────────────────────────
# Defaults (can be overridden per job)
# ──────────────────────────────────────────────
DEFAULT_PROXY_MODE=fallback
DEFAULT_CONCURRENCY=20
DEFAULT_CHUNK_SIZE=1000
MAX_RETRIES=3
DOWNLOAD_TIMEOUT=30
